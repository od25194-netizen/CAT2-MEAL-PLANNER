@* ══ Social/Chat.cshtml ══════════════════════════════════════════ *@
@{
    ViewData["Title"] = "Community Chat";
    var rooms   = ViewBag.Rooms   as List<MyMealPlanner.Core.Models.ChatRoom>    ?? new();
    var active  = ViewBag.Active  as MyMealPlanner.Core.Models.ChatRoom;
    var history = ViewBag.History as List<MyMealPlanner.Core.Models.ChatMessage> ?? new();
}

<div class="container-xl py-0" style="height:calc(100vh - var(--nav-h));display:flex">

    <!-- ══ Rooms Sidebar ══════════════════════════════════════════ -->
    <div class="border-end d-flex flex-column"
         style="width:280px;flex-shrink:0;background:var(--white)">

        <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
            <span class="fw-bold">💬 Community Chat</span>
            <button class="btn btn-orange btn-sm" data-bs-toggle="modal" data-bs-target="#new-room-modal">
                <i class="bi bi-plus"></i>
            </button>
        </div>

        <!-- Room List -->
        <div class="flex-grow-1 overflow-y-auto p-2">
            @foreach (var room in rooms)
            {
                <a asp-action="Chat" asp-route-roomId="@room.Id"
                   class="d-flex align-items-center gap-2 p-3 rounded-2 text-decoration-none mb-1
                          @(active?.Id == room.Id ? "bg-orange-light" : "")"
                   style="transition:.15s"
                   onmouseover="if(!this.classList.contains('bg-orange-light')) this.style.background='var(--light)'"
                   onmouseout="if(!this.classList.contains('bg-orange-light')) this.style.background=''">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;background:var(--orange-light);font-size:1.2rem;flex-shrink:0">
                        @(room.IsLiveSession ? "📺" : room.IsDirectMessage ? "👤" : "🍽️")
                    </div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="fw-semibold small" style="color:var(--dark)">@room.Name</div>
                        @if (!string.IsNullOrEmpty(room.CultureTag))
                        { <div class="text-muted" style="font-size:.72rem">@room.CultureTag</div> }
                    </div>
                    <div class="text-muted" style="font-size:.72rem">@room.MemberCount 👥</div>
                </a>
            }

            @if (!rooms.Any())
            {
                <div class="text-center text-muted py-4 small">
                    <i class="bi bi-chat-dots fs-2 d-block mb-2"></i>
                    No rooms yet. Create one!
                </div>
            }
        </div>
    </div>

    <!-- ══ Chat Area ══════════════════════════════════════════════ -->
    <div class="flex-grow-1 d-flex flex-column" style="min-width:0">
        @if (active != null)
        {
            <!-- Chat Header -->
            <div class="p-3 border-bottom d-flex align-items-center gap-3 bg-white">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:40px;height:40px;background:var(--orange-light);font-size:1.2rem">
                    @(active.IsLiveSession ? "📺" : "🍽️")
                </div>
                <div>
                    <div class="fw-bold">@active.Name</div>
                    @if (!string.IsNullOrEmpty(active.Description))
                    { <div class="text-muted small">@active.Description</div> }
                </div>
                <div class="ms-auto text-muted small">
                    @active.MemberCount members online
                </div>
            </div>

            <!-- Messages -->
            <div class="flex-grow-1 overflow-y-auto p-4" id="chat-messages"
                 style="background:var(--light);display:flex;flex-direction:column;gap:.75rem">
                @foreach (var msg in history)
                {
                    var isOwn = msg.SenderId == ViewBag.CurrentUserId?.ToString();
                    <div class="d-flex gap-2 align-items-end @(isOwn ? "flex-row-reverse" : "")">
                        @if (!isOwn)
                        {
                            <div class="avatar-sm flex-shrink-0" style="width:32px;height:32px;font-size:.75rem">
                                @msg.Sender?.FullName?.FirstOrDefault()
                            </div>
                        }
                        <div style="max-width:70%">
                            @if (!isOwn)
                            {
                                <div class="small fw-semibold mb-1" style="color:var(--orange)">
                                    @msg.Sender?.FullName
                                </div>
                            }
                            <div class="p-3 rounded-3"
                                 style="background:@(isOwn ? "var(--orange)" : "var(--white)");
                                        color:@(isOwn ? "white" : "var(--dark)");
                                        border-bottom-@(isOwn ? "right" : "left")-radius:4px;
                                        box-shadow:var(--shadow-sm)">
                                @if (!string.IsNullOrEmpty(msg.ImageUrl))
                                {
                                    <img src="@msg.ImageUrl" class="img-fluid rounded-2 mb-2"
                                         style="max-height:200px" />
                                }
                                @if (msg.SharedRecipeId.HasValue)
                                {
                                    <div class="p-2 rounded-2 mb-2"
                                         style="background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.3)">
                                        <i class="bi bi-book me-1"></i>
                                        <a asp-controller="Recipe" asp-action="Details"
                                           asp-route-id="@msg.SharedRecipeId"
                                           style="color:@(isOwn ? "white" : "var(--orange)")">
                                            Shared a Recipe
                                        </a>
                                    </div>
                                }
                                @msg.Body
                            </div>
                            <div class="small text-muted mt-1 @(isOwn ? "text-end" : "")">
                                @msg.SentAt.ToString("h:mm tt")
                                @if (isOwn && msg.IsRead)
                                { <i class="bi bi-check2-all text-primary ms-1"></i> }
                            </div>
                        </div>
                    </div>
                }

                <!-- Typing indicator -->
                <div id="typing-indicator" class="d-none">
                    <div class="d-flex gap-2 align-items-center">
                        <div class="avatar-sm" style="width:32px;height:32px;font-size:.75rem">?</div>
                        <div class="p-2 px-3 rounded-3"
                             style="background:var(--white);box-shadow:var(--shadow-sm)">
                            <span id="typing-user" class="small text-muted"></span> is typing
                            <span class="typing-dots ms-1">
                                <span>.</span><span>.</span><span>.</span>
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Input Bar -->
            <div class="p-3 border-top bg-white d-flex gap-2 align-items-end">
                <button class="btn btn-icon" id="attach-btn" title="Attach image">
                    <i class="bi bi-image"></i>
                </button>
                <div class="flex-grow-1">
                    <textarea id="chat-input"
                              class="form-control"
                              rows="1"
                              placeholder="Type a message…"
                              style="resize:none;max-height:120px;overflow-y:auto"
                              onkeydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault();sendChatMessage()}"></textarea>
                </div>
                <button class="btn btn-orange" id="send-btn" onclick="sendChatMessage()">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        }
        else
        {
            <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-center text-muted">
                <div style="font-size:5rem">💬</div>
                <h3 class="display-font mt-3">Pick a room</h3>
                <p class="text-center" style="max-width:340px">
                    Select a community room from the sidebar, or create your own cooking community.
                </p>
                <button class="btn btn-orange mt-2" data-bs-toggle="modal" data-bs-target="#new-room-modal">
                    <i class="bi bi-plus-circle me-2"></i>Create a Room
                </button>
            </div>
        }
    </div>
</div>

@if (active != null)
{
    @section Scripts {
    <script>
    const roomId = @active.Id;
    const currentUserId = '@ViewBag.CurrentUserId';
    const msgs = document.getElementById('chat-messages');

    // Scroll to bottom on load
    msgs.scrollTop = msgs.scrollHeight;

    // SignalR Chat
    const connection = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/chat').withAutomaticReconnect().build();

    connection.on('NewMessage', data => {
        const isOwn = data.senderId === currentUserId;
        const html = `
        <div class="d-flex gap-2 align-items-end ${isOwn ? 'flex-row-reverse' : ''}">
            ${!isOwn ? `<div class="avatar-sm flex-shrink-0" style="width:32px;height:32px;font-size:.75rem">${data.senderName?.[0] ?? '?'}</div>` : ''}
            <div style="max-width:70%">
                ${!isOwn ? `<div class="small fw-semibold mb-1" style="color:var(--orange)">${data.senderName}</div>` : ''}
                <div class="p-3 rounded-3" style="background:${isOwn ? 'var(--orange)' : 'var(--white)'};color:${isOwn ? 'white' : 'var(--dark)'};box-shadow:var(--shadow-sm)">
                    ${data.imageUrl ? `<img src="${data.imageUrl}" class="img-fluid rounded-2 mb-2" style="max-height:200px" />` : ''}
                    ${data.body}
                </div>
                <div class="small text-muted mt-1 ${isOwn ? 'text-end' : ''}">${new Date(data.sentAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}</div>
            </div>
        </div>`;
        msgs.insertAdjacentHTML('beforeend', html);
        msgs.scrollTop = msgs.scrollHeight;
    });

    connection.on('Typing', data => {
        const el = document.getElementById('typing-indicator');
        const user = document.getElementById('typing-user');
        if (data.isTyping && data.senderId !== currentUserId) {
            el?.classList.remove('d-none');
            if (user) user.textContent = data.userName;
        } else {
            el?.classList.add('d-none');
        }
    });

    connection.start().then(() => connection.invoke('JoinRoom', roomId)).catch(console.error);

    let typingTimeout;
    document.getElementById('chat-input')?.addEventListener('input', function() {
        clearTimeout(typingTimeout);
        connection.invoke('SendTyping', roomId, true).catch(() => {});
        typingTimeout = setTimeout(() => connection.invoke('SendTyping', roomId, false).catch(() => {}), 2000);
    });

    window.sendChatMessage = function() {
        const input = document.getElementById('chat-input');
        const body  = input?.value?.trim();
        if (!body) return;
        connection.invoke('SendMessage', roomId, body, null, null).catch(console.error);
        input.value = '';
        input.style.height = 'auto';
    };

    // Auto-resize textarea
    document.getElementById('chat-input')?.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });
    </script>
    }
}
