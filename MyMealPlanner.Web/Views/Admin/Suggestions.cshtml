@* ══ Admin/Suggestions.cshtml ════════════════════════════════════ *@
@model List<MyMealPlanner.Core.Models.RecipeSuggestion>
@using MyMealPlanner.Core.Enums
@{ ViewData["Title"] = "Recipe Suggestions"; var status = (SuggestionStatus)(ViewBag.Status ?? SuggestionStatus.Pending); }

<div class="container-xl py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-font mb-0">💡 Recipe Suggestions</h1>
        <div class="d-flex gap-2">
            @foreach (SuggestionStatus s in Enum.GetValues<SuggestionStatus>())
            {
                <a asp-action="Suggestions" asp-route-status="@s"
                   class="btn btn-sm @(s == status ? "btn-orange" : "btn-outline-orange")">@s</a>
            }
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
            <p>No @status suggestions at this time.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var s in Model)
            {
                <div class="bg-white rounded-3 shadow-sm p-4">
                    <div class="row g-3 align-items-start">
                        @if (!string.IsNullOrEmpty(s.CoverImageUrl))
                        {
                            <div class="col-auto">
                                <img src="@s.CoverImageUrl" style="width:80px;height:80px;object-fit:cover;border-radius:10px" />
                            </div>
                        }
                        <div class="col">
                            <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                <h5 class="fw-bold mb-0">@s.Title</h5>
                                @if (!string.IsNullOrEmpty(s.CountryOfOrigin))
                                { <span class="tag tag-country">🌍 @s.CountryOfOrigin</span> }
                                @if (s.AIQualityScore.HasValue)
                                {
                                    <span class="tag @(s.AIQualityScore >= 80 ? "tag-green" : s.AIQualityScore >= 50 ? "tag-orange" : "tag-red")">
                                        AI Score: @s.AIQualityScore.Value.ToString("F0")%
                                    </span>
                                }
                            </div>
                            <p class="text-muted small mb-2">@s.Description</p>
                            <div class="small text-muted">
                                Submitted by: <strong>@(s.SubmittedByUser?.FullName ?? "Unknown")</strong>
                                · @s.SubmittedAt.ToString("MMM d, yyyy h:mm tt")
                            </div>
                            @if (!string.IsNullOrEmpty(s.ReviewNote))
                            {
                                <div class="mt-2 small p-2 rounded-2" style="background:var(--light-2)">
                                    <i class="bi bi-chat-square-text"></i> @s.ReviewNote
                                </div>
                            }
                        </div>
                        @if (s.Status == SuggestionStatus.Pending || s.Status == SuggestionStatus.UnderReview)
                        {
                            <div class="col-auto d-flex flex-column gap-2">
                                <button class="btn btn-success btn-sm approve-btn" data-id="@s.Id">
                                    <i class="bi bi-check2"></i> Approve
                                </button>
                                <button class="btn btn-danger btn-sm reject-btn" data-id="@s.Id">
                                    <i class="bi bi-x"></i> Reject
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
document.querySelectorAll('.approve-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
        const note = prompt('Optional approval note:');
        const fd = new FormData();
        fd.append('id', btn.dataset.id);
        fd.append('note', note || '');
        fd.append('__RequestVerificationToken', document.querySelector('[name=__RequestVerificationToken]')?.value || '');
        await fetch('/Admin/ApproveSuggestion', { method: 'POST', body: fd });
        btn.closest('.bg-white').style.opacity = '.4';
        btn.textContent = '✅ Approved';
    });
});
document.querySelectorAll('.reject-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
        const reason = prompt('Reason for rejection:');
        if (!reason) return;
        const fd = new FormData();
        fd.append('id', btn.dataset.id);
        fd.append('reason', reason);
        fd.append('__RequestVerificationToken', document.querySelector('[name=__RequestVerificationToken]')?.value || '');
        await fetch('/Admin/RejectSuggestion', { method: 'POST', body: fd });
        btn.closest('.bg-white').style.opacity = '.4';
    });
});
</script>
@Html.AntiForgeryToken()
}
