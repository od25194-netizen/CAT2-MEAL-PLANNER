@* ══ Account/ForgotPasswordConfirmation.cshtml ══════════════════ *@
@{ ViewData["Title"] = "Reset Link Sent"; }
<div class="container py-5 text-center" style="max-width:480px">
    <div style="font-size:4rem">📬</div>
    <h1 class="display-font mt-3">Reset Link Sent</h1>
    <p class="text-muted mt-2 mb-4">
        If an account exists for that email, a password reset link has been sent.
        The link expires in <strong>15 minutes</strong>.
    </p>
    <div class="p-4 rounded-3 mb-4" style="background:var(--orange-light)">
        <p class="mb-0 small">
            Check your spam folder if you don't see it.
            For security, we don't confirm whether an account exists for that address.
        </p>
    </div>
    <a asp-controller="Account" asp-action="Login" class="btn btn-orange">Back to Sign In</a>
</div>
