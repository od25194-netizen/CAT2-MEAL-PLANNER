@* ForgotPassword.cshtml *@
@model MyMealPlanner.Web.ViewModels.ForgotPasswordViewModel
@{ ViewData["Title"] = "Forgot Password"; }

<div class="container py-5" style="max-width:460px">
    <div class="text-center mb-4">
        <div style="font-size:3rem">🔑</div>
        <h1 class="display-font" style="font-size:1.8rem">Reset Your Password</h1>
        <p class="text-muted">Enter your email and we'll send you a reset link valid for 15 minutes.</p>
    </div>
    <div class="bg-white rounded-3 p-4 shadow-sm">
        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger py-2 small mb-3"></div>
            <div class="mb-4">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control" type="email"
                       placeholder="you@example.com" autofocus />
            </div>
            <button type="submit" class="btn btn-orange w-100 py-2">Send Reset Link</button>
        </form>
    </div>
    <div class="text-center mt-3">
        <a asp-action="Login" class="small text-orange">← Back to Sign In</a>
    </div>
</div>
