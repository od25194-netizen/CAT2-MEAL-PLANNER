@* ══ Account/ChangePassword.cshtml ══════════════════════════════ *@
@model MyMealPlanner.Web.ViewModels.ChangePasswordViewModel
@{ ViewData["Title"] = "Change Password"; }

<div class="container py-5" style="max-width:480px">
    <h1 class="display-font mb-4">🔒 Change Password</h1>
    <div class="bg-white rounded-3 p-4 shadow-sm">
        <form asp-action="ChangePassword" method="post" asp-controller="Account">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger py-2 small mb-3"></div>
            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label">Current Password</label>
                <input asp-for="CurrentPassword" type="password" class="form-control" autofocus />
            </div>
            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">New Password</label>
                <input asp-for="NewPassword" type="password" class="form-control"
                       placeholder="Min 8 chars, uppercase, number, symbol" />
            </div>
            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-orange flex-grow-1 py-2">Update Password</button>
                <a asp-action="Settings" class="btn btn-outline-orange">Cancel</a>
            </div>
        </form>
    </div>
</div>
