@* ══ Account/RegisterConfirmation.cshtml ════════════════════════ *@
@{ ViewData["Title"] = "Check Your Email"; }
<div class="container py-5 text-center" style="max-width:480px">
    <div style="font-size:4rem">📧</div>
    <h1 class="display-font mt-3">Check Your Email</h1>
    <p class="text-muted mt-2 mb-4">
        We've sent a confirmation link to your email address.
        Click the link to activate your account — it expires in 24 hours.
    </p>
    <div class="p-4 rounded-3 mb-4" style="background:var(--orange-light)">
        <p class="mb-0 small">
            <strong>Didn't receive it?</strong> Check your spam folder.
            If it's still not there after a few minutes,
            <a asp-controller="Account" asp-action="ResendConfirmation" class="text-orange">click here to resend</a>.
        </p>
    </div>
    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-orange">Back to Sign In</a>
</div>
