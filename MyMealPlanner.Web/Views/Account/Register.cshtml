@{
    ViewData["Title"] = "Create Account";
    int step = ViewBag.Step ?? 1;
    var countries = new[] {
        ("NG","🇳🇬 Nigeria"),("GH","🇬🇭 Ghana"),("KE","🇰🇪 Kenya"),("ZA","🇿🇦 South Africa"),
        ("ET","🇪🇹 Ethiopia"),("EG","🇪🇬 Egypt"),("MA","🇲🇦 Morocco"),("US","🇺🇸 United States"),
        ("GB","🇬🇧 United Kingdom"),("CA","🇨🇦 Canada"),("AU","🇦🇺 Australia"),
    };
}

<div class="auth-wrapper d-flex align-items-center justify-content-center min-vh-100 py-5">
    <div class="auth-card glass-morphism p-4 p-md-5 animate-slide-up" style="max-width: 620px; width: 100%;">
        <div class="text-center mb-4">
            <div class="auth-logo mb-2">🍽️</div>
            <h1 class="display-font h3 fw-bold text-dark">Join My Meal Planner</h1>
            <p class="text-muted small">Step @step of 3 — @(step == 1 ? "Your Profile" : step == 2 ? "Food Identity" : "Safety & Finalize")</p>
        </div>

        <!-- Progress Bar -->
        <div class="progress mb-4" style="height: 6px; border-radius: 10px;">
            <div class="progress-bar bg-orange" role="progressbar" style="width: @(step * 33.33)%; transition: width 0.5s ease-in-out;"></div>
        </div>

        @if (step == 1)
        {
            <!-- Social First -->
            <div class="d-grid gap-2 mb-4">
                <form asp-action="ExternalLogin" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="provider" value="Google" />
                    <button type="submit" class="btn btn-social btn-google w-100">
                        <svg width="18" height="18" class="me-2" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                        Sign up with Google
                    </button>
                </form>
            </div>
            <div class="separator mb-4"><span>or use email</span></div>

            <form asp-action="RegisterStep1" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-12">
                        <div class="form-floating mb-3">
                            <input name="FullName" class="form-control" placeholder="Name" required />
                            <label>Full Name</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-floating mb-3">
                            <input name="Email" type="email" class="form-control" placeholder="Email" required />
                            <label>Email Address</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3 position-relative">
                            <input name="Password" type="password" class="form-control" id="reg-pwd" placeholder="Password" required oninput="checkStrength(this.value)" />
                            <label>Password</label>
                            <div id="pwd-meter" class="mt-1" style="height:4px; border-radius:10px;"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input name="ConfirmPassword" type="password" class="form-control" placeholder="Repeat" required />
                            <label>Confirm Password</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input name="DateOfBirth" type="date" class="form-control" required />
                            <label>Date of Birth</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <select name="CountryCode" class="form-select" required>
                                <option value="">Select...</option>
                                @foreach (var (code, name) in countries) { <option value="@code">@name</option> }
                            </select>
                            <label>Country</label>
                        </div>
                    </div>
                </div>
                <button type="submit" class="btn btn-orange w-100 py-3 rounded-pill fw-bold mt-4 hover-up">
                    Next Step <i class="bi bi-arrow-right ms-1"></i>
                </button>
            </form>
        }

        @if (step == 2)
        {
            <form asp-action="RegisterStep2" method="post" class="animate-fade-in">
                @Html.AntiForgeryToken()
                <div class="form-floating mb-4">
                    <input name="FavouriteDish" class="form-control" placeholder="Dish" />
                    <label>What's your favourite dish?</label>
                </div>

                <div class="mb-4">
                    <label class="fw-bold text-dark mb-3 d-block">Dietary Lifestyle</label>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var diet in new[] { "Vegan","Vegetarian","Halal","Keto","Paleo","Gluten-Free" })
                        {
                            <input type="checkbox" class="btn-check" name="DietaryRestrictions" value="@diet" id="diet-@diet">
                            <label class="btn btn-outline-orange rounded-pill btn-sm px-3" for="diet-@diet">@diet</label>
                        }
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input name="NumberOfPeopleICookFor" type="number" class="form-control" value="2" />
                            <label>Cooking for how many?</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <select name="HealthGoal" class="form-select">
                                <option value="Weight_Loss">Weight Loss</option>
                                <option value="Muscle_Gain">Muscle Gain</option>
                                <option value="Better_Energy">Better Energy</option>
                            </select>
                            <label>Health Goal</label>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-orange w-100 py-3 rounded-pill fw-bold hover-up">
                    Continue <i class="bi bi-arrow-right ms-1"></i>
                </button>
            </form>
        }

        @if (step == 3)
        {
            <form asp-action="RegisterStep3" method="post" class="animate-fade-in">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label class="fw-bold text-dark mb-3 d-block">Allergies (Critical Safety)</label>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var a in new[] { "Peanuts","Milk","Eggs","Gluten","Soy","Shellfish" })
                        {
                            <input type="checkbox" class="btn-check" name="Allergies" value="@a" id="all-@a">
                            <label class="btn btn-outline-danger rounded-pill btn-sm px-3" for="all-@a">@a</label>
                        }
                    </div>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input custom-checkbox" type="checkbox" required id="terms" />
                    <label class="form-check-label small text-muted" for="terms">
                        I agree to the <a href="#" class="text-orange">Terms</a> and <a href="#" class="text-orange">Privacy Policy</a>
                    </label>
                </div>

                <button type="submit" class="btn btn-orange w-100 py-3 rounded-pill fw-bold hover-up">
                    Complete Registration <i class="bi bi-check-lg ms-1"></i>
                </button>
            </form>
        }

        <p class="text-center mt-4 mb-0 text-muted small">
            Already have an account? 
            <a asp-controller="Account" asp-action="Login" class="text-orange fw-bold text-decoration-none">Sign In</a>
        </p>
    </div>
</div>

<style>
    .auth-wrapper { background: linear-gradient(135deg, #FFF5F0 0%, #FFE4D6 100%); position: relative; overflow: hidden; }
    .auth-card { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(15px); border-radius: 30px; border: 1px solid rgba(255, 255, 255, 0.4); box-shadow: 0 25px 50px -12px rgba(232, 99, 10, 0.15); }
    .auth-logo { font-size: 3rem; }

    .btn-social { height: 50px; border-radius: 12px; font-weight: 600; display: flex; align-items: center; justify-content: center; }
    .btn-google { background: white; border: 1px solid #E5E7EB; color: #374151; }
    
    .separator { text-align: center; position: relative; z-index: 1; }
    .separator::before { content: ""; position: absolute; left: 0; top: 50%; width: 100%; height: 1px; background: #E5E7EB; z-index: -1; }
    .separator span { background: #FFF9F7; padding: 0 15px; color: #9CA3AF; font-size: 0.8rem; }

    .form-control, .form-select { border-radius: 12px; border: 1.5px solid #F3F4F6; }
    .form-control:focus, .form-select:focus { border-color: #E8630A; box-shadow: 0 0 0 4px rgba(232, 99, 10, 0.1); }

    .btn-outline-orange { border-color: #E8630A; color: #E8630A; }
    .btn-check:checked + .btn-outline-orange { background-color: #E8630A; border-color: #E8630A; color: white; }
    
    .btn-outline-danger { border-color: #dc3545; color: #dc3545; }
    .btn-check:checked + .btn-outline-danger { background-color: #dc3545; border-color: #dc3545; color: white; }

    .animate-slide-up { animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate-fade-in { animation: fadeIn 0.4s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>

<script>
    function checkStrength(v) {
        const meter = document.getElementById('pwd-meter');
        const strength = [/[A-Z]/.test(v), /\d/.test(v), /[^a-zA-Z\d]/.test(v), v.length >= 8].filter(Boolean).length;
        const colors = ['#f3f4f6','#dc3545','#ffc107','#28a745','#059669'];
        meter.style.width = (strength * 25) + '%';
        meter.style.backgroundColor = colors[strength];
    }
</script>
