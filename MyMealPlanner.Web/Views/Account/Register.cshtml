@using MyMealPlanner.Core.Enums
@{
    ViewData["Title"] = "Create Your Account";
    int step = ViewBag.Step ?? 1;
    var countries = new[] {
        ("NG","🇳🇬 Nigeria"),("GH","🇬🇭 Ghana"),("KE","🇰🇪 Kenya"),("ZA","🇿🇦 South Africa"),
        ("ET","🇪🇹 Ethiopia"),("EG","🇪🇬 Egypt"),("MA","🇲🇦 Morocco"),("US","🇺🇸 United States"),
        ("GB","🇬🇧 United Kingdom"),("CA","🇨🇦 Canada"),("AU","🇦🇺 Australia"),
        ("FR","🇫🇷 France"),("DE","🇩🇪 Germany"),("IT","🇮🇹 Italy"),("ES","🇪🇸 Spain"),
        ("IN","🇮🇳 India"),("JP","🇯🇵 Japan"),("CN","🇨🇳 China"),("BR","🇧🇷 Brazil"),
        ("MX","🇲🇽 Mexico"),("NG","🇸🇦 Saudi Arabia"),("AE","🇦🇪 UAE"),("TR","🇹🇷 Turkey"),
    };
    var langs = new[] {
        ("en","🇬🇧 English"),("fr","🇫🇷 Français"),("es","🇪🇸 Español"),("pt","🇧🇷 Português"),
        ("ar","🇸🇦 العربية"),("zh","🇨🇳 中文"),("hi","🇮🇳 हिन्दी"),("sw","🇰🇪 Kiswahili"),
        ("de","🇩🇪 Deutsch"),("it","🇮🇹 Italiano"),("ja","🇯🇵 日本語"),("ko","🇰🇷 한국어"),
    };
}

<div class="container py-5" style="max-width:580px">

    <!-- Logo -->
    <div class="text-center mb-4">
        <div style="font-size:3rem">🍽️</div>
        <h1 class="display-font" style="font-size:2rem">Join My Meal Planner</h1>
        <p class="text-muted">Discover recipes from every corner of the world</p>
    </div>

    <!-- Step indicator -->
    <div class="step-indicator justify-content-center mb-4">
        @for (int i = 1; i <= 3; i++)
        {
            <div class="step-dot @(i < step ? "done" : i == step ? "active" : "")"></div>
            if (i < 3) { <div style="flex:1;height:2px;background:var(--light-2);border-radius:1px"></div> }
        }
    </div>
    <div class="text-center text-muted small mb-4">
        Step @step of 3 —
        @(step == 1 ? "Basic Info" : step == 2 ? "Food Identity" : "Finishing Up")
    </div>

    <!-- OAuth Buttons (step 1 only) -->
    @if (step == 1)
    {
        <div class="d-flex flex-column gap-2 mb-4">
            <form asp-action="ExternalLogin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="provider" value="Google" />
                <input type="hidden" name="returnUrl" value="" />
                <button type="submit" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
                    <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                    Continue with Google
                </button>
            </form>
            <form asp-action="ExternalLogin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="provider" value="Facebook" />
                <input type="hidden" name="returnUrl" value="" />
                <button type="submit" class="btn w-100 d-flex align-items-center justify-content-center gap-2"
                        style="background:#1877F2;color:white;border:none">
                    <i class="bi bi-facebook"></i> Continue with Facebook
                </button>
            </form>
        </div>
        <div class="d-flex align-items-center gap-2 mb-4">
            <hr class="flex-grow-1" /><span class="text-muted small">or register with email</span><hr class="flex-grow-1" />
        </div>
    }

    <!-- Card -->
    <div class="bg-white rounded-3 p-4 shadow-sm">

        <!-- ══ STEP 1 ══════════════════════════════════════════ -->
        @if (step == 1)
        {
            <form asp-action="RegisterStep1" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Full Name *</label>
                    <input name="FullName" type="text" class="form-control" placeholder="e.g. Amara Johnson" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email Address *</label>
                    <input name="Email" type="email" class="form-control" placeholder="you@example.com" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password *</label>
                    <div class="input-group">
                        <input name="Password" type="password" class="form-control" id="pwd-input"
                               placeholder="Min 8 chars, uppercase, number, symbol" required />
                        <button type="button" class="btn btn-outline-secondary" id="pwd-toggle">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div id="pwd-strength" class="mt-1"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Confirm Password *</label>
                    <input name="ConfirmPassword" type="password" class="form-control"
                           placeholder="Repeat password" required />
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Date of Birth *</label>
                        <input name="DateOfBirth" type="date" class="form-control" required
                               max="@DateTime.Today.AddYears(-13).ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Country *</label>
                        <select name="CountryCode" class="form-select" required>
                            <option value="">Select country…</option>
                            @foreach (var (code, name) in countries)
                            { <option value="@code">@name</option> }
                        </select>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label">Preferred Language</label>
                    <select name="PreferredLanguage" class="form-select">
                        @foreach (var (code, name) in langs)
                        { <option value="@code">@name</option> }
                    </select>
                </div>
                <button type="submit" class="btn btn-orange w-100 py-2">
                    Continue <i class="bi bi-arrow-right ms-1"></i>
                </button>
            </form>
        }

        <!-- ══ STEP 2 ══════════════════════════════════════════ -->
        @if (step == 2)
        {
            <form asp-action="RegisterStep2" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">What's your favourite dish?</label>
                    <input name="FavouriteDish" type="text" class="form-control"
                           placeholder="e.g. Jollof Rice, Pasta, Sushi…" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Dietary Restrictions <span class="text-muted fw-normal">(select all that apply)</span></label>
                    <div class="row g-2">
                        @foreach (var diet in new[] { "Vegan","Vegetarian","Halal","Kosher","Gluten-Free","Dairy-Free","Nut-Free","Pescatarian" })
                        {
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           name="DietaryRestrictions" value="@diet" id="diet-@diet" />
                                    <label class="form-check-label" for="diet-@diet">@diet</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Known Allergies <span class="text-muted fw-normal">(important for safety)</span></label>
                    <div class="row g-2">
                        @foreach (var allergy in new[] { "Peanuts","Tree Nuts","Milk","Eggs","Wheat/Gluten","Soy","Fish","Shellfish","Sesame" })
                        {
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           name="Allergies" value="@allergy" id="allergy-@allergy.Replace("/","")" />
                                    <label class="form-check-label" for="allergy-@allergy.Replace("/","")">@allergy</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">How many people do you cook for?</label>
                        <input name="NumberOfPeopleICookFor" type="number" class="form-control"
                               value="2" min="1" max="50" />
                        <div class="form-text">Recipes will auto-scale to this number</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Health Goal</label>
                        <select name="HealthGoal" class="form-select">
                            @foreach (var goal in Enum.GetValues<HealthGoal>())
                            { <option value="@goal">@goal.ToString().Replace("_"," ")</option> }
                        </select>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label">Favourite Cuisines <span class="text-muted fw-normal">(select up to 5)</span></label>
                    <div class="row g-2">
                        @foreach (var c in new[] { "West African","East African","Italian","Japanese","Indian","Mexican","Middle Eastern","Chinese","French","Caribbean","Mediterranean","Korean" })
                        {
                            <div class="col-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           name="FavouriteCuisines" value="@c" id="cui-@c.Replace(" ","")" />
                                    <label class="form-check-label small" for="cui-@c.Replace(" ","")">@c</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <button type="submit" class="btn btn-orange w-100 py-2">
                    Continue <i class="bi bi-arrow-right ms-1"></i>
                </button>
            </form>
        }

        <!-- ══ STEP 3 ══════════════════════════════════════════ -->
        @if (step == 3)
        {
            <form asp-action="RegisterStep3" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Bio <span class="text-muted fw-normal">(optional)</span></label>
                    <textarea name="Bio" class="form-control" rows="2" maxlength="500"
                              placeholder="Tell the community a little about yourself…"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Hobbies <span class="text-muted fw-normal">(optional)</span></label>
                    <input name="Hobbies" type="text" class="form-control"
                           placeholder="e.g. Hiking, Photography, Football…" />
                </div>
                <div class="mb-3">
                    <label class="form-label">
                        Blood Type
                        <span class="tag tag-blue ms-1" style="font-size:.7rem">Optional · Beta</span>
                    </label>
                    <select name="BloodType" class="form-select">
                        <option value="">Prefer not to say</option>
                        @foreach (var bt in Enum.GetValues<BloodType>().Where(b => b != BloodType.Unknown))
                        { <option value="@bt">@bt.ToString().Replace("Positive","+").Replace("Negative","-")</option> }
                    </select>
                    <div class="form-text">Used only for personalised meal suggestions. Encrypted and never shared.</div>
                </div>

                <!-- Pet Section -->
                <div class="p-3 rounded-3 mb-4" style="background:var(--orange-light)">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span style="font-size:1.5rem">🐾</span>
                        <label class="form-label mb-0 fw-bold">Do you have a pet?</label>
                        <div class="form-check form-switch ms-auto mb-0">
                            <input class="form-check-input" type="checkbox" id="has-pet-toggle" name="HasPet" />
                        </div>
                    </div>
                    <div id="pet-section" class="d-none">
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label small">Pet Name</label>
                                <input name="Pets[0].PetName" type="text" class="form-control form-control-sm"
                                       placeholder="e.g. Max, Luna…" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small">Type</label>
                                <select name="Pets[0].PetType" class="form-select form-select-sm">
                                    @foreach (var pt in Enum.GetValues<PetType>())
                                    { <option value="@pt">@pt</option> }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small">Breed (optional)</label>
                                <input name="Pets[0].Breed" type="text" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small">Age (years)</label>
                                <input name="Pets[0].AgeYears" type="number" class="form-control form-control-sm"
                                       value="1" min="0" max="30" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Terms -->
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="AcceptTerms" id="terms" required />
                        <label class="form-check-label small" for="terms">
                            I agree to the <a href="#" target="_blank">Terms of Service</a>
                            and <a href="#" target="_blank">Privacy Policy</a> *
                        </label>
                    </div>
                </div>
                <div class="mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="AcceptCookies" id="cookies" required />
                        <label class="form-check-label small" for="cookies">
                            I consent to cookie usage for personalised experience *
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn btn-orange w-100 py-2">
                    🎉 Create My Account
                </button>
            </form>
        }
    </div>

    <div class="text-center mt-4 text-muted small">
        Already have an account?
        <a asp-controller="Account" asp-action="Login" class="text-orange fw-semibold">Sign in</a>
    </div>
</div>

@section Scripts {
<script>
// Password toggle
document.getElementById('pwd-toggle')?.addEventListener('click', () => {
    const i = document.getElementById('pwd-input');
    i.type = i.type === 'password' ? 'text' : 'password';
});

// Password strength
document.getElementById('pwd-input')?.addEventListener('input', function() {
    const v = this.value;
    const el = document.getElementById('pwd-strength');
    if (!el) return;
    const strength = [/[A-Z]/.test(v), /\d/.test(v), /[^a-zA-Z\d]/.test(v), v.length >= 8].filter(Boolean).length;
    const labels = ['','Weak 🔴','Fair 🟡','Good 🟢','Strong 💪'];
    const colors = ['','#E84646','#F5A623','#22A86B','#059669'];
    el.innerHTML = strength ? `<div class="small fw-semibold" style="color:${colors[strength]}">${labels[strength]}</div>` : '';
});

// Pet toggle
document.getElementById('has-pet-toggle')?.addEventListener('change', function() {
    document.getElementById('pet-section')?.classList.toggle('d-none', !this.checked);
});
</script>
}
