@* ══ Account/DeleteAccount.cshtml ═══════════════════════════════ *@
@model MyMealPlanner.Web.ViewModels.DeleteAccountViewModel
@{ ViewData["Title"] = "Delete Account"; }

<div class="container py-5" style="max-width:520px">
    <div class="text-center mb-4">
        <div style="font-size:3rem">⚠️</div>
        <h1 class="display-font text-danger" style="font-size:1.8rem">Delete Your Account</h1>
        <p class="text-muted">This action cannot be easily undone. Please read carefully.</p>
    </div>

    <div class="alert d-flex gap-3 mb-4" style="background:#FFF0F0;border:2px solid var(--red);border-radius:var(--radius)">
        <i class="bi bi-exclamation-octagon-fill text-danger flex-shrink-0 fs-4 mt-1"></i>
        <div>
            <strong>What will be deleted after 30 days:</strong>
            <ul class="mb-0 mt-1 small">
                <li>Your profile and personal information</li>
                <li>Your cook logs and collections</li>
                <li>Your messages and notifications</li>
                <li>Your pet profiles</li>
            </ul>
            <div class="mt-2 small">
                <strong>What stays (anonymised):</strong>
                Community-approved recipes will remain attributed to "Deleted User".
            </div>
        </div>
    </div>

    <div class="bg-white rounded-3 p-4 shadow-sm">
        <p class="text-muted small mb-3">
            You have a <strong>30-day grace period</strong> to cancel — just log back in.
            After 30 days, all data is permanently wiped per our GDPR policy.
        </p>
        <form asp-action="DeleteAccount" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger py-2 small mb-3"></div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold">
                    Confirm with your password
                </label>
                <input asp-for="Password" type="password" class="form-control"
                       placeholder="Enter your current password" autofocus />
            </div>
            <div class="form-check mb-4">
                <input asp-for="Confirmed" class="form-check-input" type="checkbox" />
                <label asp-for="Confirmed" class="form-check-label small">
                    I understand my data will be permanently deleted after 30 days
                </label>
            </div>
            <button type="submit"
                    class="btn w-100 py-2 fw-bold"
                    style="background:var(--red);color:white;border:none">
                <i class="bi bi-trash3"></i> Schedule Account Deletion
            </button>
        </form>
        <div class="text-center mt-3">
            <a asp-action="Settings" class="small text-muted">← Cancel — Keep My Account</a>
        </div>
    </div>
</div>
