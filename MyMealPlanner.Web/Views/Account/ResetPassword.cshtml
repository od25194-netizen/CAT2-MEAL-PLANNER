@* ══ Account/ResetPassword.cshtml ═══════════════════════════════ *@
@model MyMealPlanner.Web.ViewModels.ResetPasswordViewModel
@{ ViewData["Title"] = "Set New Password"; }

<div class="container py-5" style="max-width:440px">
    <div class="text-center mb-4">
        <div style="font-size:3rem">🔑</div>
        <h1 class="display-font" style="font-size:1.8rem">Set New Password</h1>
    </div>
    <div class="bg-white rounded-3 p-4 shadow-sm">
        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />
            <div asp-validation-summary="All" class="alert alert-danger py-2 small mb-3"></div>
            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">New Password</label>
                <input asp-for="NewPassword" type="password" class="form-control"
                       placeholder="Min 8 chars, uppercase, number, symbol" autofocus />
            </div>
            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control"
                       placeholder="Repeat new password" />
            </div>
            <button type="submit" class="btn btn-orange w-100 py-2">Reset Password</button>
        </form>
    </div>
</div>
