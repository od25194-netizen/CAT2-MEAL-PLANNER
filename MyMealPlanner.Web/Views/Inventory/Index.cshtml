@model List<MyMealPlanner.Core.Models.CookingEquipment>
@{ ViewData["Title"] = "Kitchen Inventory"; }

<div class="container-xl py-5">
    <div class="d-flex justify-content-between align-items-center mb-5 fade-up">
        <div>
            <h1 class="display-font text-dark mb-1">🔪 Kitchen Inventory</h1>
            <p class="text-muted mb-0">Manage your tools and learn proper maintenance.</p>
        </div>
        <button class="btn btn-orange rounded-pill px-4 shadow-sm fw-bold">
            <i class="bi bi-camera me-2"></i> Identify Tool (AI)
        </button>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card h-100 border-0 shadow-sm overflow-hidden" style="border-radius: 15px;">
                    <div class="bg-light p-5 text-center">
                        <i class="bi bi-tools text-muted fs-1"></i>
                    </div>
                    <div class="card-body p-3">
                        <span class="badge bg-light text-muted fw-normal mb-2">@item.Category</span>
                        <h6 class="fw-bold mb-1">@item.Name</h6>
                        <p class="text-muted small mb-0">@item.Description</p>
                    </div>
                    <div class="card-footer bg-white border-0 p-3 pt-0">
                        <button class="btn btn-sm btn-link text-orange text-decoration-none p-0 fw-bold" 
                                data-bs-toggle="collapse" data-bs-target="#care-@item.Id">
                            Care Instructions <i class="bi bi-chevron-down small"></i>
                        </button>
                        <div class="collapse mt-2" id="care-@item.Id">
                            <div class="p-2 bg-light rounded-3 small">
                                <div class="fw-bold text-dark">Cleaning:</div>
                                <div class="text-muted">@item.CleaningSteps</div>
                                <div class="fw-bold text-dark mt-2">Maintenance:</div>
                                <div class="text-muted">@item.MaintenanceTips</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
