@* ═══ Jokes/Index.cshtml ══════════════════════════════════════════ *@
@model List<MyMealPlanner.Core.Models.CookingJoke>
@{
    ViewData["Title"] = "The Kitchen Stage — Cooking Jokes";
    var categories = ViewBag.Categories as List<string> ?? new();
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var selectedCat = ViewBag.SelectedCat as string;
}

<div class="container-xl py-4">
    <!-- Hero -->
    <div class="text-center py-4 mb-4">
        <div style="font-size:3.5rem">😂</div>
        <h1 class="display-font">The Kitchen Stage</h1>
        <p class="text-muted">Fresh cooking jokes scraped daily + AI-generated humour. Laughter is the best seasoning.</p>

        <div class="d-flex gap-2 justify-content-center flex-wrap mt-3">
            <a asp-action="Index" class="tag @(selectedCat == null ? "tag-orange" : "tag-country")"
               style="cursor:pointer;font-size:.9rem">All</a>
            @foreach (var cat in categories)
            {
                <a asp-action="Index" asp-route-category="@cat"
                   class="tag @(selectedCat == cat ? "tag-orange" : "tag-country")"
                   style="cursor:pointer;font-size:.9rem">@cat</a>
            }
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row g-3">
            @foreach (var joke in Model)
            {
                <div class="col-12 col-md-6 fade-up">
                    <div class="joke-card">
                        <p class="mb-3" style="font-family:var(--font-display);font-size:1.05rem;line-height:1.6">
                            @joke.Body
                        </p>
                        <div class="d-flex align-items-center gap-3">
                            @if (!string.IsNullOrEmpty(joke.Category))
                            {
                                <span class="tag tag-orange">@joke.Category</span>
                            }
                            <span class="tag tag-country ms-auto">
                                @joke.Source
                            </span>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <button class="btn btn-sm btn-outline-orange like-joke-btn"
                                        data-joke-id="@joke.Id">
                                    <i class="bi bi-hand-thumbs-up"></i>
                                    <span class="like-count">@joke.LikeCount</span>
                                </button>
                            }
                            else
                            {
                                <span class="small text-muted">
                                    <i class="bi bi-hand-thumbs-up"></i> @joke.LikeCount
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-center gap-2 mt-5">
                @for (int p = 1; p <= totalPages; p++)
                {
                    <a asp-action="Index" asp-route-page="@p" asp-route-category="@selectedCat"
                       class="btn btn-sm @(p == currentPage ? "btn-orange" : "btn-outline-orange")">@p</a>
                }
            </div>
        }

        <!-- Random Joke button -->
        <div class="text-center mt-4">
            <button class="btn btn-orange btn-lg" id="random-joke-btn">
                🎲 Surprise Me!
            </button>
        </div>

        <!-- Random Joke Modal -->
        <div class="modal fade" id="random-joke-modal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 rounded-3">
                    <div class="modal-body text-center p-5">
                        <div style="font-size:3rem">😂</div>
                        <p id="random-joke-text" class="mt-3"
                           style="font-family:var(--font-display);font-size:1.2rem;line-height:1.6"></p>
                        <button class="btn btn-orange mt-3" id="another-joke-btn">Another one! 🎲</button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-emoji-neutral fs-1 d-block mb-3"></i>
            <p>No jokes yet — the chef is still thinking…</p>
        </div>
    }
</div>

@section Scripts {
<script>
// Like joke
document.querySelectorAll('.like-joke-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
        const id = btn.dataset.jokeId;
        const resp = await fetch(`/Jokes/LikeJoke/${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': document.querySelector('[name=__RequestVerificationToken]')?.value || '' }
        });
        const data = await resp.json();
        btn.querySelector('.like-count').textContent = data.likeCount;
        btn.classList.replace('btn-outline-orange','btn-orange');
    });
});

// Random joke
const modal = new bootstrap.Modal(document.getElementById('random-joke-modal'));
async function loadRandomJoke() {
    const resp = await fetch('/Jokes/Random');
    const joke = await resp.json();
    document.getElementById('random-joke-text').textContent = joke?.body || 'No joke found!';
}
document.getElementById('random-joke-btn')?.addEventListener('click', async () => {
    await loadRandomJoke(); modal.show();
});
document.getElementById('another-joke-btn')?.addEventListener('click', loadRandomJoke);
</script>
@Html.AntiForgeryToken()
}
