@* ═══ Quiz/Index.cshtml ══════════════════════════════════════════ *@
@using MyMealPlanner.Core.Enums
@{
    ViewData["Title"] = "Chef Quiz — Level Up";
    var currentLevel = (ChefLevel)(ViewBag.CurrentLevel ?? ChefLevel.Level1_KitchenNewcomer);
    var nextLevel    = ViewBag.NextLevel as ChefLevel?;
    var canAttempt   = (bool)(ViewBag.CanAttempt ?? false);
    var last         = ViewBag.LastAttempt as MyMealPlanner.Core.Models.QuizAttempt;
}

<div class="container py-5" style="max-width:720px">
    <div class="text-center mb-5">
        <div style="font-size:3.5rem">🏆</div>
        <h1 class="display-font">Chef Level Quiz</h1>
        <p class="text-muted">Take personalised quizzes based on your cooking history to level up.</p>
    </div>

    <!-- Current Level Card -->
    <div class="quiz-card mb-4 text-center">
        <div class="d-flex justify-content-center gap-4 mb-4">
            @{
                var levels = new[] {
                    (ChefLevel.Level1_KitchenNewcomer, "Kitchen Newcomer", ""),
                    (ChefLevel.Level2_CuriousCook, "Curious Cook", ""),
                    (ChefLevel.Level3_HomeExplorer, "Home Explorer", ""),
                    (ChefLevel.Level4_ConfidentCook, "Confident Cook", "⚪"),
                    (ChefLevel.Level5_SkilledChef, "Skilled Chef", "⚪"),
                    (ChefLevel.Level6_ExpertCulinarian, "Expert Culinarian", "🟢"),
                    (ChefLevel.Level7_MasterChef, "Master Chef", "🟢"),
                    (ChefLevel.Level8_GrandChef, "Grand Chef", "🌟"),
                };
            }
            @foreach (var (lvl, name, tick) in levels)
            {
                var active = lvl == currentLevel;
                var done   = (int)lvl < (int)currentLevel;
                <div class="d-flex flex-column align-items-center gap-1">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:36px;height:36px;background:@(active?"var(--orange)":done?"var(--green)":"var(--light-2)");color:white;font-weight:700;font-size:.8rem;transition:.3s">
                        @((int)lvl)
                    </div>
                    <div class="small" style="font-size:.65rem;max-width:60px;text-align:center;color:var(--mid)">
                        @(tick) @name.Split(' ')[0]
                    </div>
                </div>
                @if ((int)lvl < 8)
                {
                    <div style="height:2px;width:20px;background:@(done?"var(--green)":"var(--light-2)");align-self:center;border-radius:1px"></div>
                }
            }
        </div>

        <div class="p-3 rounded-3 mb-4" style="background:var(--orange-light)">
            <div class="fw-bold">@currentLevel.ToString().Replace("_"," ")</div>
            @if (nextLevel.HasValue)
            {
                <div class="small text-muted mt-1">
                    Next: Level @((int)nextLevel.Value) — @nextLevel.Value.ToString().Replace("_"," ")
                    @(nextLevel.Value switch {
                        ChefLevel.Level4_ConfidentCook or ChefLevel.Level5_SkilledChef => "⚪",
                        ChefLevel.Level6_ExpertCulinarian or ChefLevel.Level7_MasterChef => "🟢",
                        ChefLevel.Level8_GrandChef => "🌟",
                        _ => ""
                    })
                </div>
            }
        </div>

        <!-- Last Attempt -->
        @if (last != null)
        {
            <div class="p-3 rounded-3 mb-4" style="background:var(--light-2)">
                <div class="fw-semibold mb-1">Last Quiz</div>
                <div class="d-flex justify-content-center gap-4 small">
                    <span>Score: <strong>@last.ScorePercent.ToString("F0")%</strong></span>
                    <span>@last.CorrectAnswers/@last.TotalQuestions correct</span>
                    <span>@(last.IsPassed ? "✅ Passed" : "❌ Not passed")</span>
                </div>
                @if (last.NextAttemptAllowedAt > DateTime.UtcNow)
                {
                    <div class="small text-muted mt-2">
                        Next attempt available: <strong>@last.NextAttemptAllowedAt?.ToString("f")</strong>
                    </div>
                }
            </div>
        }

        @if (canAttempt && nextLevel.HasValue)
        {
            <a asp-action="Take" class="btn btn-orange btn-lg px-5">
                <i class="bi bi-mortarboard me-2"></i>Take Quiz for Level @((int)nextLevel.Value)
            </a>
            <p class="small text-muted mt-2">10 questions · Personalised to your food history · 48hr cooldown after attempt</p>
        }
        else if (!nextLevel.HasValue)
        {
            <div class="tag tag-gold">🌟 You are a Grand Chef — the highest level!</div>
        }
        else
        {
            <div class="text-muted small">Quiz will be available after the cooldown period.</div>
        }
    </div>

    <!-- Rules -->
    <div class="bg-white rounded-3 shadow-sm p-4">
        <h5 class="fw-bold mb-3">📋 How It Works</h5>
        <div class="d-flex flex-column gap-3">
            @{
                var rules = new[] {
                    ("🎯","Personalised questions","Generated from your recipe history, searches, and cuisines you've explored"),
                    ("📊","8 question types","Multiple choice, image ID, video clip, drag-and-drop steps, and more"),
                    ("⏱️","48-hour cooldown","Must wait before re-attempting to prevent grinding"),
                    ("🎖️","Levels 4–5","Score 80%+ to earn White Tick ⚪"),
                    ("🟢","Levels 6–7","Score 90%+ to earn Green Tick"),
                    ("🌟","Level 8 — Grand Chef","Admin review + community vote required. Gold Tick awarded"),
                };
            }
            @foreach (var (icon, title, desc) in rules)
            {
                <div class="d-flex gap-3 align-items-start">
                    <div style="font-size:1.5rem;flex-shrink:0">@icon</div>
                    <div>
                        <div class="fw-semibold">@title</div>
                        <div class="small text-muted">@desc</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
