# ══════════════════════════════════════════════════════════════
# My Meal Planner — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
# SQL Server (LocalDB for development)
CONNECTIONSTRINGS__DEFAULTCONNECTION=Server=(localdb)\\mssqllocaldb;Database=MyMealPlannerDb;Trusted_Connection=True;

# PostgreSQL alternative (Render/Railway free tier)
# CONNECTIONSTRINGS__DEFAULTCONNECTION=Host=localhost;Database=mymealplanner;Username=postgres;Password=yourpassword

# Redis (optional — falls back to in-memory)
CONNECTIONSTRINGS__REDIS=localhost:6379

# ── Authentication (OAuth) ────────────────────────────────────
# Google: console.cloud.google.com → Credentials → OAuth 2.0
AUTH__GOOGLE__CLIENTID=your-google-client-id.apps.googleusercontent.com
AUTH__GOOGLE__CLIENTSECRET=your-google-client-secret

# Facebook: developers.facebook.com → My Apps
AUTH__FACEBOOK__APPID=your-facebook-app-id
AUTH__FACEBOOK__APPSECRET=your-facebook-app-secret

# ── AI Services (use cheapest available) ─────────────────────
# DeepSeek: platform.deepseek.com — BEST VALUE, very capable (recommended #1)
AI__DEEPSEEK_APIKEY=sk-your-deepseek-api-key
AI__DEEPSEEKMODEL=deepseek-chat

# Groq: console.groq.com — FREE tier, fast Llama 3 (recommended #2)
AI__GROQAPIKEY=gsk_your_groq_api_key

# Ollama: run locally — docker run -d -p 11434:11434 ollama/ollama
AI__OLLAMABASEURL=http://localhost:11434
AI__OLLAMAMODEL=llama3

# OpenRouter: openrouter.ai — cheap multi-model gateway
AI__OPENROUTERAPIKEY=sk-or-your-openrouter-key

# Claude (Anthropic): console.anthropic.com — most capable
AI__CLAUDEAPIKEY=sk-ant-your-claude-key

# ── YouTube ───────────────────────────────────────────────────
# Google Cloud Console → APIs → YouTube Data API v3
# Free: 10,000 units/day
YOUTUBE__APIKEY=AIza-your-youtube-api-key

# ── Google Vision (Image Search) ─────────────────────────────
# Google Cloud Console → APIs → Cloud Vision API
# Free: 1,000 units/month
GOOGLEVISION__APIKEY=AIza-your-vision-api-key

# ── Google Maps ───────────────────────────────────────────────
# Google Cloud Console → APIs → Places API
# Free: $200/month credit
GOOGLEMAPS__APIKEY=AIza-your-maps-api-key

# ── Translation ───────────────────────────────────────────────
# Self-host: docker run -p 5000:5000 libretranslate/libretranslate
LIBRETRANSLATE__BASEURL=http://localhost:5000
LIBRETRANSLATE__APIKEY=

# ── Email (MailKit) ───────────────────────────────────────────
# Gmail: myaccount.google.com → Security → App passwords
EMAIL__SMTPHOST=smtp.gmail.com
EMAIL__SMTPPORT=587
EMAIL__USERNAME=your-app-email@gmail.com
EMAIL__PASSWORD=your-gmail-app-password
EMAIL__FROMNAME=My Meal Planner

# ── Image Storage ─────────────────────────────────────────────
# Cloudinary: cloudinary.com — free 25GB
CLOUDINARY__CLOUDNAME=your-cloud-name
CLOUDINARY__APIKEY=your-cloudinary-key
CLOUDINARY__APISECRET=your-cloudinary-secret

# ── App Settings ─────────────────────────────────────────────
APP__BASEURL=https://mymealplanner.app
SEED__ADMINEMAIL=admin@mymealplanner.app
SEED__ADMINPASSWORD=Admin@MyMealPlanner2024!
